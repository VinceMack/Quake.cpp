{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            //"args": ["-winsize", "640", "480", "-fullscreen"],
            //"args": ["-winsize", "1280", "960", "-fullscreen"],
            "args": ["-winsize", "1920", "1080", "-fullscreen"],
            "cwd": "${command:cmake.launchTargetDirectory}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ]
}
